[Unit]
Description=AMD LLM Gateway Proxy
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/opt/amd-node-setup
EnvironmentFile=-/etc/amd-node-setup/amdproxy.env
ExecStart=/usr/bin/python3 /opt/amd-node-setup/proxy/amd_proxy.py
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
